# ============================================================
# Claude Telegram Relay — Environment Variables
# ============================================================
# Copy to .env:  cp .env.example .env
# Then fill in your values below.
# ============================================================

# --- REQUIRED: Telegram ---

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Your Telegram user ID (from @userinfobot)
TELEGRAM_USER_ID=your_telegram_user_id

# --- REQUIRED: Supabase (persistent memory) ---

# Project URL (looks like https://abc123.supabase.co)
SUPABASE_URL=your_project_url

# anon public key (starts with eyJ...)
SUPABASE_ANON_KEY=your_anon_key

# --- RECOMMENDED: Personalization ---

# Your first name
USER_NAME=Your Name

# Your timezone (IANA format: America/New_York, Europe/Berlin, etc.)
USER_TIMEZONE=UTC

# --- OPTIONAL: Paths ---

# Claude CLI path (auto-detected if in PATH)
# CLAUDE_PATH=claude

# Long-lived Max-plan auth token from `claude setup-token`. When set, the CLI
# authenticates with it directly — no per-spawn OAuth refresh, so no refresh-
# token rotation race under concurrent crons. Leave blank to fall back to
# ~/.claude/.credentials.json. Update with `pm2 restart --update-env atlas`.
# CLAUDE_CODE_OAUTH_TOKEN=

# Working directory for Claude (defaults to relay's own directory)
# PROJECT_DIR=/path/to/your/project

# Relay data directory (defaults to ~/.claude-relay)
# RELAY_DIR=~/.claude-relay

# --- OPTIONAL: Voice Transcription ---

# Voice provider: "groq" (free cloud API) or "local" (whisper.cpp on your machine)
# VOICE_PROVIDER=groq

# For Groq: Free API key from console.groq.com
# GROQ_API_KEY=your_groq_key

# For local whisper.cpp:
# WHISPER_BINARY=whisper-cpp
# WHISPER_MODEL_PATH=~/whisper-models/ggml-base.en.bin

# ============================================================
# Atlas Prime — prompt cache TTL
# ============================================================

# Atlas Prime: opt into 1h prompt cache TTL (default on, overridable).
# Cache reads are ~10% of input-token cost; for cron-spaced calls
# this is the difference between paying nothing and paying full price.
ENABLE_PROMPT_CACHING_1H=1

# Atlas Prime Sprint 2
REPLAY_DATASET_PATH=data/replay-dataset.jsonl
TRUST_MIN_SCORE=0.65
READER_MAX_CHARS=40000

# Atlas Prime Sprint 3
RERANKER_MODEL_ID=Xenova/bge-reranker-base
MEMORY_REWRITE_DAILY_LIMIT=50
MEMORY_REWRITE_MIN_AGE_DAYS=7
MEMORY_REWRITE_MIN_ACCESS=5

# Atlas Prime Sprint 4
TWIN_DIVERGENCE_GAP_ALERT=0.4
TWIN_MIN_SAMPLE_SIZE=5
WORLD_MODEL_PRIMARY=amazon/chronos-bolt-base
WORLD_MODEL_FALLBACK=Xenova/chronos-bolt-tiny
CAUSAL_PC_STABILITY_THRESHOLD=0.7

# Atlas Prime Sprint 5 — The Society
# (No required new env vars. All Sprint 5 modules use existing SUPABASE_*, ANTHROPIC_API_KEY.)
# Optional override:
# COUNCIL_SLA_MS=3000
# JOINT_ROUTINE_DEADLINE_HOURS=2

# Atlas Prime Sprint 6
DGM_NIGHTLY_BUDGET_USD=3
DGM_VARIANTS_PER_NIGHT=5
SHADOW_PROMOTE_THRESHOLD=7
SHADOW_WINDOW_SIZE=10
SHADOW_DEMOTE_WINDOW_DAYS=30
SOFT_DPO_INJECT_TOPK=3
INTROSPECT_TTL_DAYS=30

# ============================================================
# Atlas Prime Sprint 7 — Bulletproofing
# ============================================================

# Shadow-Atlas
SHADOW_ATLAS_ENABLED=true
SHADOW_ATLAS_MODEL=sonnet
SHADOW_BUDGET_MS=90000
SHADOW_DRIFT_THRESHOLD=0.45

# Entropy probe
ENTROPY_PROBE_ENABLED=true
ENTROPY_PROBE_SAMPLES=5
ENTROPY_THRESHOLD=0.8

# Knowledge audit
KNOWLEDGE_AUDIT_SAMPLE_SIZE=8

# Public beacon
BEACON_PUBLIC_REPO=atlas-prime-beacon
BEACON_BOUNTY_USD=500

# Memory-signing strictness (set true after Sprint 7 fully shipped + session-key init verified)
MEMORY_SIGNING_STRICT=false

# Inference engine for callClaude(): "cli" (default, REQUIRED for the relay) or "sdk".
#
# KEEP THIS "cli" FOR THE RELAY. Hard-won lesson (2026-05-28): the SDK one-shot
# query() respawns all MCP servers EVERY turn (no warm pool), which flaps GHL in
# and out and starves real-time data. The only SDK fix is streaming/persistent
# mode (keeps MCP warm across turns) — but that's BLOCKED on Windows by an open
# upstream bug: anthropics/claude-agent-sdk-python#208 (ClaudeSDKClient hangs on
# init; subprocess never returns the control_response). Atlas runs on Windows 11.
# The CLI persistent-process pool already keeps MCP warm and is Windows-hardened —
# that's why GHL was rock-solid before. The relay belongs on the CLI pool.
#
# The SDK engine IS fully built/tested/committed (src/engine/*, flag-gated, the
# CLI path is untouched). It's solid for BOUNDED, one-shot work — pilot it on the
# code-agent runner, not the hot relay. Do NOT set =sdk on the relay until #208 is
# fixed or Atlas runs under WSL2.
# Flip (only if you know why): ATLAS_ENGINE=sdk + `pm2 restart atlas --update-env`.
ATLAS_ENGINE=cli
