{
  "permissions": {
    "deny": [
      "Bash(rm -rf*)",
      "Bash(del /s*)",
      "Bash(format*)",
      "Bash(Remove-Item -Recurse*)",
      "Bash(*id_rsa*)",
      "Bash(*credentials.json*)",
      "Bash(*.pem*)",
      "Bash(*.key*)",
      "Bash(cat .env*)",
      "Bash(type .env*)",
      "Bash(Get-Content .env*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(npm publish*)"
    ],
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "TodoWrite",
      "Bash(pm2 *)",
      "Bash(pm2 restart*)",
      "Bash(pm2 stop*)",
      "Bash(pm2 start*)",
      "Bash(pm2 list*)",
      "Bash(pm2 logs*)",
      "Bash(pm2 delete*)",
      "Bash(pm2 status*)",
      "Bash(pm2 info*)",
      "Bash(pm2 describe*)",
      "Bash(bun *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(pip *)",
      "Bash(python *)",
      "Bash(curl *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(cd *)",
      "Bash(echo *)",
      "Bash(pwd*)",
      "Bash(which *)",
      "Bash(where *)",
      "Write",
      "Edit",
      "Bash(mkdir -p .claude/*)",
      "Bash(cat > .claude/*)",
      "Bash(tee .claude/*)",
      "Agent",
      "Bash(npm *)",
      "Bash(npx *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"$input = $env:TOOL_INPUT; if ($input -match '(rm\s+-rf|del\s+/s|format\s+[a-z]:|Remove-Item.*-Recurse|id_rsa|credentials\.json|\.pem|\.key)') { exit 2 } else { exit 0 }\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/guard-claude-dir.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/guard-claude-dir.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/pre-compact-snapshot.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/post-compact-verify.sh"
          }
        ]
      }
    ]
  }
}
