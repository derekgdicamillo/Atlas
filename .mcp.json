{
  "mcpServers": {
    "brevo": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.brevo.com/v1/brevo/mcp",
        "--header",
        "Authorization: Bearer ${BREVO_MCP_TOKEN}"
      ],
      "env": {
        "BREVO_MCP_TOKEN": "${BREVO_MCP_TOKEN}"
      }
    }
  }
}
